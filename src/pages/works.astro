---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import Text from "../components/Text.jsx";

const works = [
    {
        titleKey: "page_works.work1_title",
        descKey: "page_works.work1_desc",
        img: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=1200&q=80",
    },
    {
        titleKey: "page_works.work2_title",
        descKey: "page_works.work2_desc",
        img: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1200&q=80",
    },
    {
        titleKey: "page_works.work3_title",
        descKey: "page_works.work3_desc",
        img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&q=80",
    }
];
---

<Layout>
    <NavBar />
    
    <main class="page-container">
        <header class="page-header">
            <h1 class="page-title"><Text client:only="react" i18nKey="page_works.title" /></h1>
            <p class="page-subtitle"><Text client:only="react" i18nKey="page_works.subtitle" /></p>
        </header>

        <section class="works-list">
            {works.map((work, index) => (
                <article class="work-card">
                    <div class="work-img-wrapper">
                        <img src={work.img} alt={`Work ${index + 1}`} class="work-img" />
                    </div>
                    <div class="work-content">
                        <h2><Text client:only="react" i18nKey={work.titleKey} /></h2>
                        <p><Text client:only="react" i18nKey={work.descKey} /></p>
                    </div>
                </article>
            ))}
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .page-container {
        padding-top: 15vh;
        min-height: 100vh;
        width: 90%;
        margin: 0 auto;
        color: var(--contrast);
    }

    .page-header {
        margin-bottom: 10vh;
        text-align: left;
    }

    .page-title {
        font-size: clamp(3rem, 6vw, 6rem);
        margin-bottom: 2rem;
        line-height: 1.1;
    }

    .page-subtitle {
        font-size: clamp(1.2rem, 2vw, 2rem);
        color: var(--gris2);
        max-width: 800px;
        line-height: 1.5;
    }

    .works-list {
        display: flex;
        flex-direction: column;
        gap: 15vh;
        padding-bottom: 15vh;
    }

    .work-card {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        width: 100%;
    }

    /* Diseño alterno (izquierda / derecha) si hay espacio */
    @media (min-width: 900px) {
        .work-card {
            flex-direction: row;
            align-items: center;
        }
        .work-card:nth-child(even) {
            flex-direction: row-reverse;
        }
        .work-img-wrapper {
            flex: 1.2;
        }
        .work-content {
            flex: 1;
            padding: 0 4rem;
        }
    }

    .work-img-wrapper {
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        width: 100%;
        aspect-ratio: 16 / 9;
    }

    .work-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .work-card:hover .work-img {
        transform: scale(1.05);
    }

    .work-content h2 {
        font-size: clamp(2rem, 3vw, 4rem);
        margin-bottom: 1.5rem;
        line-height: 1.2;
    }

    .work-content p {
        font-size: clamp(1.1rem, 1.5vw, 1.5rem);
        color: var(--gris2);
        line-height: 1.6;
    }
</style>
