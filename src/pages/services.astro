<script>
    function setupFilters() {
        const buttons = document.querySelectorAll(".niche-btn");
        const specificCards = document.querySelectorAll(".agency-category");
        const wrapper = document.getElementById("specificCardsWrapper");

        if (!wrapper || !buttons.length) return;

        // Inicializamos con pymes activo, ya que en el HTML está así por defecto
        let activeCategory = "pymes";

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const category = btn.getAttribute("data-filter");

                // Si se hace clic en la categoría que ya está abierta, no hacemos nada
                // para evitar que el estado quede vacío.
                if (activeCategory === category) return;

                activeCategory = category;

                // Actualizar estado activo en botones
                buttons.forEach((b) => {
                    b.classList.toggle("active", b === btn);
                });

                // Ocultar todas las tarjetas y preparar animación
                specificCards.forEach((card) => {
                    card.style.display = "none";
                    card.style.opacity = "0";
                    card.style.transform = "translateY(20px)";
                });

                // Mostrar y animar la seleccionada
                const matchedCards = document.querySelectorAll(
                    `.agency-category[data-category="${category}"]`,
                );
                matchedCards.forEach((card) => {
                    card.style.display = "block";
                    // Forzar reflow para que la transición de CSS se ejecute
                    void card.offsetWidth;
                    card.style.transition =
                        "opacity 0.6s ease, transform 0.6s ease";
                    card.style.opacity = "1";
                    card.style.transform = "translateY(0)";
                });

                wrapper.style.gridTemplateRows = "1fr";
            });
        });
    }

    document.addEventListener("DOMContentLoaded", setupFilters);
    document.addEventListener("astro:page-load", setupFilters);
</script>

<style>
