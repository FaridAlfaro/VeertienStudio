---
import LanguageSelector from "./LanguageSelector.jsx";
import Text from "./Text.jsx";
---

<header class="navbar">
    <a href="/" class="logo-container">
        <img src="/logos/logo.svg" alt="Logo" />
    </a>

    <button class="hamburger" aria-label="Menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
    </button>

    <nav>
        <ul class="nav-links">
            <li>
                <a href="/services" class="nav-item">
                    <Text client:only="react" i18nKey="nav.what_we_do" />
                </a>
            </li>
            <li>
                <a href="/works" class="nav-item">
                    <Text client:only="react" i18nKey="nav.works" />
                </a>
            </li>
            <li>
                <a href="/about" class="nav-item">
                    <Text client:only="react" i18nKey="nav.who_we_are" />
                </a>
            </li>
            <li>
                <a href="#footer" class="nav-item">
                    <Text client:only="react" i18nKey="nav.contact" />
                </a>
            </li>
            <li class="lang-selector-container">
                <LanguageSelector client:only="react" />
            </li>
        </ul>
    </nav>
</header>

<script>
    function initScrollBehavior() {
        const navbar = document.querySelector(".navbar");

        // Evitamos duplicar el listener en transiciones de Astro
        if (!navbar || navbar.dataset.scrollInit) return;
        navbar.dataset.scrollInit = "true";

        let lastScrollY = window.scrollY;

        window.addEventListener(
            "scroll",
            () => {
                if (navbar.classList.contains("menu-open")) return;

                const currentScrollY = window.scrollY;

                if (currentScrollY <= 0) {
                    navbar.classList.remove("navbar-hidden");
                } else if (currentScrollY > lastScrollY) {
                    navbar.classList.add("navbar-hidden");
                } else {
                    navbar.classList.remove("navbar-hidden");
                }

                lastScrollY = currentScrollY;
            },
            { passive: true },
        );
    }

    function initMobileMenu() {
        const navbar = document.querySelector(".navbar");
        const hamburger = document.querySelector(".hamburger");
        const navLinks = document.querySelector(".nav-links");

        if (!hamburger || !navLinks) return;

        // Evitamos duplicar eventos de click en transiciones de Astro
        if (hamburger.dataset.menuInit) return;
        hamburger.dataset.menuInit = "true";

        hamburger.addEventListener("click", () => {
            const isActive = hamburger.classList.toggle("is-active");
            navLinks.classList.toggle("nav-active");
            navbar.classList.toggle("menu-open", isActive);

            // Bloquea el scroll del fondo cuando el menú está abierto
            document.body.style.overflow = isActive ? "hidden" : "";
        });

        // Cerrar el menú si hacen click en un link
        document.querySelectorAll(".nav-item").forEach((item) => {
            item.addEventListener("click", () => {
                hamburger.classList.remove("is-active");
                navLinks.classList.remove("nav-active");
                navbar.classList.remove("menu-open");
                document.body.style.overflow = "";
            });
        });
    }

    const initNav = () => {
        initScrollBehavior();
        initMobileMenu();
    };

    document.addEventListener("DOMContentLoaded", initNav);
    document.addEventListener("astro:page-load", initNav);
</script>

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0%;
        width: 100%;
        height: 8vh;
        min-height: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 5%;
        box-sizing: border-box;
        z-index: 1000;
        background: var(--background);
        color: var(--contrast); /* Negro */
        transition:
            transform 1s cubic-bezier(0.25, 1, 0.5, 1),
            background-color 0.5s ease;
    }

    .navbar.menu-open {
        transform: none !important;
    }

    .navbar.navbar-hidden {
        transform: translateY(-150%);
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    img {
        height: 2vh;
        margin-bottom: 4%;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 3vw;
        margin: 0;
        padding: 0;
        z-index: 2000;
    }

    .nav-item {
        text-decoration: none;
        color: var(--contrast);
        font-size: 1.6rem;
        font-weight: 500;
        position: relative;
        padding-bottom: 4px;
        display: inline-block;
    }

    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 16px;
        height: 15px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 1002;
    }

    .hamburger .bar {
        width: 100%;
        height: 2px;
        background-color: var(--contrast);
        border-radius: 10px;
        transition: all 0.3s ease-in-out;
    }

    .hamburger.is-active .bar:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
    }

    .hamburger.is-active .bar:nth-child(2) {
        opacity: 0;
    }

    .hamburger.is-active .bar:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
    }

    /* Efecto Hover mantenido */
    .nav-item::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: 0;
        left: 0;
        background-color: var(--azul3, #000); /* Ajusta a tu variable */
        transform: scaleX(0);
        transform-origin: right center;
        transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .nav-item:hover::after {
        transform: scaleX(1);
        transform-origin: left center;
    }

    @media (max-width: 1440px) {
        .nav-item {
            font-size: 1.4rem;
        }
    }

    @media (max-width: 1024px) {
        .nav-item {
            font-size: 1.2rem;
        }
        .nav-links {
            gap: 2vw;
        }
    }

    @media (max-width: 768px) {
        .hamburger {
            display: flex;
            position: absolute;
            right: 5%;
        }

        nav {
            position: absolute;
            width: 0;
            height: 0;
            overflow: visible;
        }

        .nav-links {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100dvh;
            background-color: var(--background); /* Blanco */
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5vh;
            z-index: 1001; /* Queda debajo del hamburger (1002) */

            /* Estado cerrado: movido hacia la derecha */
            transform: translateX(100%);
            transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }

        /* Estado Abierto: entra en pantalla */
        .nav-links.nav-active {
            transform: translateX(0);
        }

        .nav-links li {
            list-style: none;
        }

        .nav-item {
            font-size: 2.2rem;
            color: var(--contrast); /* Negro */
        }

        .navbar {
            padding: 0 4%;
        }
    }
</style>
