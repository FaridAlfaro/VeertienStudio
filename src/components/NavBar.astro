---
import LanguageSelector from './LanguageSelector.jsx';
import Text from './Text.jsx';
---

<header class="navbar">
    <a href="/" class="logo-container">
        <img src="/logos/logo.svg" alt="" />
    </a>

    <nav>
        <ul class="nav-links">
            <li><a href="/services" class="nav-item"><Text client:only="react" i18nKey="nav.what_we_do" /></a></li>
            <li><a href="/works" class="nav-item"><Text client:only="react" i18nKey="nav.works" /></a></li>
            <li><a href="/about" class="nav-item"><Text client:only="react" i18nKey="nav.who_we_are" /></a></li>
            <li><a href="#footer" class="nav-item"><Text client:only="react" i18nKey="nav.contact" /></a></li>
            <li><LanguageSelector client:only="react" /></li>
        </ul>
    </nav>
</header>

<script>
    import { animate } from "animejs";

    function initNavAnimation() {
        const navElements = document.querySelectorAll(
            ".logo-container, .nav-item",
        );

        if (navElements.length === 0) return;

        // Animación de entrada en cascada al cargar la página
        animate(navElements, {
            translateY: [-20, 0],
            opacity: [0, 1],
            duration: 800,
            delay: (el, i) => i * 100, // Retraso en cascada
            easing: "outCubic",
        });
    }

    function initScrollBehavior() {
        const navbar = document.querySelector(".navbar");
        if (!navbar) return;

        let lastScrollY = window.scrollY;

        window.addEventListener(
            "scroll",
            () => {
                const currentScrollY = window.scrollY;

                if (currentScrollY <= 0) {
                    navbar.classList.remove("navbar-hidden");
                } else if (currentScrollY > lastScrollY) {
                    // Descendiendo
                    navbar.classList.add("navbar-hidden");
                } else {
                    // Ascendiendo
                    navbar.classList.remove("navbar-hidden");
                }

                lastScrollY = currentScrollY;
            },
            { passive: true },
        );
    }

    document.addEventListener("DOMContentLoaded", () => {
        initNavAnimation();
        initScrollBehavior();
    });
    document.addEventListener("astro:page-load", () => {
        initNavAnimation();
        initScrollBehavior();
    }); // Si usas View Transitions
</script>

<style>
    .navbar {
        position: fixed;
        top: 1.618%;
        left: 5%;
        width: 90%;
        height: 6vh;
        min-height: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 5%; /* Mantiene el alineamiento con el 90% de ancho de tus contenedores */
        box-sizing: border-box;
        z-index: 1000; /* Asegura que esté por encima de las cards */
        background: var(--background);
        border-radius: 14px;
        transition:
            transform 1s cubic-bezier(0.25, 1, 0.5, 1),
            background-color 0.5s ease;
    }

    :global(body.dark-mode) .navbar {
        background-color: var(--contrast);
    }

    .navbar.navbar-hidden {
        transform: translateY(-150%);
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 1rem;
        opacity: 0; /* Oculto inicialmente para Anime.js */
    }

    img {
        height: 2vh;
        margin-bottom: 4%;
    }

    .logo-text {
        font-size: 2rem;
        font-weight: bold;
        font-family: monospace; /* Mantiene el toque tech */
        letter-spacing: -1px;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 3vw; /* Espaciado fluido entre enlaces */
        margin: 0;
        padding: 0;
    }

    .nav-item {
        text-decoration: none;
        color: inherit;
        font-size: 1.6rem;
        font-weight: 500;
        position: relative;
        padding-bottom: 4px;
        display: inline-block;
        opacity: 0; /* Oculto inicialmente para Anime.js */
    }

    /* El mismo efecto de subrayado que usamos en las cards */
    .nav-item::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: 0;
        left: 0;
        background-color: var(--azul3, #fff); /* Puede ser blanco o tu azul */
        transform: scaleX(0);
        transform-origin: right center; /* Empieza desde la derecha */
        transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .nav-item:hover::after {
        transform: scaleX(1);
        transform-origin: left center; /* Se despliega hacia la izquierda */
    }
</style>
