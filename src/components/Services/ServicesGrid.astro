<script>
    import { animate, remove } from "animejs";

    function initAnimations() {
        const cards = document.querySelectorAll(".card");
        if (cards.length === 0) return;

        cards.forEach((card) => {
            const content = card.querySelector(".card-content");
            const bg = card.querySelector(".card-bg");
            const p = card.querySelector("p");
            const btn = card.querySelector(".read-more");

            if (!content || !bg || !p || !btn) return;

            card.addEventListener("mouseenter", () => {
                remove([card, bg, content, p, btn]);

                animate(card, {
                    scale: 1,
                    duration: 400,
                    easing: "outCubic",
                });

                animate(bg, {
                    filter: "blur(60px) brightness(0.9)",
                    scale: 1.2,
                    translateX: "-50px",
                    translateY: "50px",
                    duration: 300,
                    easing: "outCubic",
                });

                animate(content, {
                    height: "100%",
                    opacity: 1,
                    marginTop: "16px",
                    duration: 400,
                    easing: "outCubic",
                });

                animate(p, {
                    opacity: [0, 1],
                    translateX: [40, 0],
                    duration: 400,
                    delay: 150,
                    easing: "outCubic",
                });

                animate(btn, {
                    opacity: [0, 1],
                    translateY: [30, 0],
                    duration: 400,
                    delay: 250,
                    easing: "outCubic",
                });
            });

            card.addEventListener("mouseleave", () => {
                remove([card, bg, content, p, btn]);

                animate(card, {
                    scale: 1,
                    duration: 400,
                    easing: "outCubic",
                });

                animate(bg, {
                    filter: "blur(0px) brightness(1)",
                    scale: 1,
                    translateX: "0px",
                    translateY: "0px",
                    duration: 400,
                    easing: "outCubic",
                });

                animate(content, {
                    height: "0px",
                    opacity: 0,
                    marginTop: "0px",
                    duration: 400,
                    easing: "outCubic",
                });

                animate(p, {
                    opacity: 0,
                    translateX: 40,
                    duration: 250,
                    easing: "inCubic",
                });

                animate(btn, {
                    opacity: 0,
                    translateY: 30,
                    duration: 250,
                    easing: "inCubic",
                });
            });
        });
    }

    document.addEventListener("DOMContentLoaded", initAnimations);
    document.addEventListener("astro:page-load", initAnimations);
</script>

<style is:global>
    .container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2vw;
        width: 100%;
        max-width: 90vw;
        margin: 0 auto;
    }

    .card {
        position: relative;
        height: 60vh;
        border-radius: 2px;
        overflow: hidden;
        display: flex;
        align-items: flex-start;
        color: var(--background, #fff);
        cursor: pointer;
        will-change: transform;
    }

    .card-bg {
        position: absolute;
        top: -30px;
        left: -30px;
        right: -30px;
        bottom: -30px;
        background-size: cover;
        background-position: center;
        z-index: 1;
        will-change: filter, transform;
    }

    .card-inner {
        position: relative;
        z-index: 2;
        padding: 2rem;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .card-inner.mod {
        color: var(--contrast);
    }

    .card h2 {
        margin: 0;
        font-size: 3rem;
        color: inherit;
    }

    .card-content {
        height: 0px;
        opacity: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .card-content p {
        margin: 0 0 1.5rem 0;
        font-size: 2rem;
        line-height: 1.5;
        color: inherit;
        opacity: 0;
    }

    .read-more {
        background: transparent;
        color: inherit;
        border: none;
        padding: 0;
        font-size: 2rem;
        font-weight: 600;
        cursor: pointer;
        align-self: flex-end;
        margin-top: auto;
        position: relative;
        display: inline-block;
        opacity: 0;
    }

    .read-more::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: 0;
        left: 0;
        background-color: currentColor;
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 0.3s ease-out;
    }

    .read-more:hover::after {
        transform: scaleX(1);
    }

    /* ==== RESPONSIVE ==== */
    @media (max-width: 1440px) {
        .container {
            grid-template-columns: repeat(3, 1fr);
            gap: 2vw;
        }
        .card {
            height: 45vh;
            min-height: 400px;
        }
        .card-inner {
            padding: 1.5rem;
        }
        .card h2 {
            font-size: 2.2rem;
        }
        .card-content p {
            font-size: 1.4rem;
        }
        .read-more {
            font-size: 1.4rem;
        }
    }

    @media (max-width: 1024px) {
        .container {
            grid-template-columns: repeat(2, 1fr);
            gap: 3vw;
        }
        .card {
            height: auto;
            min-height: 350px;
        }
        .card-inner {
            padding: 2rem;
        }
        .card h2 {
            font-size: 2.5rem;
        }
        .card-content p {
            font-size: 1.5rem;
        }
        .read-more {
            font-size: 1.5rem;
        }
    }

    @media (max-width: 768px) {
        .container {
            grid-template-columns: 1fr;
            gap: 4vw;
        }
        .card {
            height: auto;
            min-height: 300px;
        }
        .card-inner {
            padding: 2rem;
        }
        .card h2 {
            font-size: 2.2rem;
        }
        .card-content p {
            font-size: 1.3rem;
            margin: 0 0 1rem 0;
        }
        .read-more {
            font-size: 1.3rem;
        }

        /* OCULTAMOS LAS TARJETAS 5 Y 6 EN MÓVIL CON LA CLASE DIRECTA */
        .hide-on-mobile {
            display: none !important;
        }
    }
</style>
