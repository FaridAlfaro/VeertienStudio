---
import Text from "../Text.jsx";
import ScrambleText from "../ScrambleText.jsx";
import ServicesGrid from "./ServicesGrid.astro";

const { hideButton = false, animateBg = true } = Astro.props;
---

<section class={`services ${animateBg ? "animated-bg" : ""}`}>
    <div class="title">
        <h3>
            <Text client:only="react" i18nKey="services.title_start" />
            <ScrambleText client:only="react" i18nKey="services.problems" />
            <Text client:only="react" i18nKey="services.title_mid" />
            <ScrambleText client:only="react" i18nKey="services.sales" />
            <Text client:only="react" i18nKey="services.title_mid2" />
            <ScrambleText client:only="react" i18nKey="services.identity" />
            <Text client:only="react" i18nKey="services.title_end" />
        </h3>
    </div>

    {
        !hideButton && (
            <a href="/services" class="services-button">
                <Text client:only="react" i18nKey="services.view_all" />
                <span>&gt;</span>
            </a>
        )
    }
</section>

<script>
    import { animate, remove } from "animejs";

    function initAnimations() {
        // Validación de seguridad para evitar errores si los elementos no existen
        const section = document.querySelector(".services");
        if (!section) return;

        // --- 1. Animación Scramble y Glitch para los Spans ---
        const scrambleElements = document.querySelectorAll(".scramble-title");
        const letters = "abcdemano!@#%&*<>+";

        const getRandomChar = () =>
            letters[Math.floor(Math.random() * letters.length)];

        scrambleElements.forEach((el, index) => {
            const originalText = el.dataset.original;
            if (!originalText) return; // Validación extra

            let interval = null;
            let glitchTimeout = null;
            let isRevealed = false;

            el.style.display = "inline-block";
            el.style.minWidth = `${originalText.length}ch`;

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting && !isRevealed) {
                            setTimeout(
                                () => {
                                    let iteration = 0;
                                    clearInterval(interval);

                                    interval = setInterval(() => {
                                        el.innerText = originalText
                                            .split("")
                                            .map((letter, i) => {
                                                if (i < iteration)
                                                    return originalText[i];
                                                return getRandomChar();
                                            })
                                            .join("");

                                        if (iteration >= originalText.length) {
                                            clearInterval(interval);
                                            isRevealed = true;
                                            startRandomGlitch(el, originalText);
                                        }
                                        iteration += 1 / 3;
                                    }, 30);
                                },
                                500 + index * 200,
                            );

                            observer.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.5 },
            );

            observer.observe(el);

            function startRandomGlitch(element, text) {
                const nextGlitch = () => {
                    const timeToNext = Math.random() * 1000 + 2000;

                    glitchTimeout = setTimeout(() => {
                        const targetIndex = Math.floor(
                            Math.random() * text.length,
                        );
                        let glitchTicks = 0;
                        const maxTicks = 20;

                        const glitchInterval = setInterval(() => {
                            element.innerText = text
                                .split("")
                                .map((char, i) => {
                                    if (i === targetIndex)
                                        return getRandomChar();
                                    return char;
                                })
                                .join("");

                            glitchTicks++;
                            if (glitchTicks >= maxTicks) {
                                clearInterval(glitchInterval);
                                element.innerText = text;
                                nextGlitch();
                            }
                        }, 10);
                    }, timeToNext);
                };

                nextGlitch();
            }
        });

        // --- 2. Animaciones internas de las Cards ---
        // (Movidas al componente ServicesGrid)
    }

    document.addEventListener("DOMContentLoaded", initAnimations);
    document.addEventListener("astro:page-load", initAnimations);
</script>

<style>
    .services {
        width: 100%;
        flex: 1;
        min-height: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        background: var(--contrast);
        color: var(--background);
        position: relative;
        z-index: 10;
        padding: 0;

        /* Animación Parallax base impulsada por scroll */
        animation: subida-parallax linear forwards;
        animation-timeline: view();
        animation-range: entry 0% entry 100%;
    }

    .animated-bg {
        animation:
            subida-parallax linear forwards,
            cambio-fondo 1s ease-in-out forwards;
        animation-timeline: view(), view();
        animation-range:
            entry 0% entry 100%,
            10% 100%;
    }

    @keyframes subida-parallax {
        0% {
            transform: translateY(10vh);
        }
        100% {
            transform: translateY(0);
        }
    }

    .services-button {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.75rem;
        margin: 3vh auto;
        padding: 1.1rem 2.8rem;
        font-size: clamp(1rem, 2vw, 1.4rem);
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        color: #fff;
        background: linear-gradient(
            135deg,
            var(--azul3, #3b82f6) 0%,
            #6366f1 100%
        );
        border: none;
        border-radius: 100px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        box-shadow:
            0 0 0 0 rgba(99, 102, 241, 0),
            0 4px 24px rgba(99, 102, 241, 0.35);
        transition:
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
            box-shadow 0.3s ease,
            letter-spacing 0.3s ease;
    }

    /* Shimmer sweep on hover */
    .services-button::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            transparent 30%,
            rgba(255, 255, 255, 0.25) 50%,
            transparent 70%
        );
        transform: translateX(-100%);
        transition: transform 0.55s ease;
    }

    /* Bottom glow line */
    .services-button::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 10%;
        width: 80%;
        height: 6px;
        border-radius: 100px;
        background: linear-gradient(90deg, var(--azul3, #3b82f6), #6366f1);
        filter: blur(8px);
        opacity: 0.7;
        transition:
            opacity 0.3s ease,
            filter 0.3s ease;
    }

    .services-button span {
        display: inline-flex;
        align-items: center;
        font-size: 1.2em;
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .services-button:hover {
        transform: translateY(-3px) scale(1.04);
        box-shadow:
            0 0 0 6px rgba(99, 102, 241, 0.15),
            0 8px 32px rgba(99, 102, 241, 0.5);
        letter-spacing: 0.1em;
    }

    .services-button:hover::before {
        transform: translateX(100%);
    }

    .services-button:hover::after {
        opacity: 1;
        filter: blur(12px);
    }

    .services-button:hover span {
        transform: translateX(4px);
    }

    .services-button:active {
        transform: translateY(-1px) scale(1.01);
    }

    .title {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 90%;
        font-size: 6rem;
        text-align: left;
        margin: 4vh 0 2vh;
        flex-shrink: 1;
    }

    .title h3 {
        margin: 0;
        font-size: inherit; /* Hereda explícitamente el tamaño que le dictan las media queries al div .title */
        font-weight: 500;
        line-height: 1.2;
    }

    .scramble-title {
        margin: 0;
        font-weight: bold;
        color: var(--azul3);
    }

    .container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2vw;
        width: 90%;
    }

    .card {
        position: relative;
        height: 60vh;
        border-radius: 2px;
        overflow: hidden;
        display: flex;
        align-items: flex-start;
        /* Usamos currentColor o var(--background) por defecto */
        color: var(--background, #fff);
        cursor: pointer;
        will-change: transform;
    }

    .card-bg {
        position: absolute;
        top: -30px;
        left: -30px;
        right: -30px;
        bottom: -30px;
        background-size: cover;
        background-position: center;
        z-index: 1;
        will-change: filter, transform;
    }

    .card-inner {
        position: relative;
        z-index: 2;
        padding: 2rem;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    /* --- ESTILOS DE LA CLASE MOD --- */
    /* Cuando .card-inner tiene la clase .mod, cambia el color de todos sus descendientes */
    .card-inner.mod {
        color: var(--contrast);
    }

    .card h2 {
        margin: 0;
        font-size: 3rem;
        color: inherit; /* Hereda el color de .card-inner */
    }

    .card-content {
        height: 0px;
        opacity: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .card-content p {
        margin: 0 0 1.5rem 0;
        font-size: 2rem;
        line-height: 1.5;
        color: inherit; /* Hereda el color de .card-inner */
        opacity: 0;
    }

    .read-more {
        background: transparent;
        color: inherit; /* Hereda el color de .card-inner */
        border: none;
        padding: 0;
        font-size: 2rem;
        font-weight: 600;
        cursor: pointer;
        align-self: flex-end;
        margin-top: auto;
        position: relative;
        display: inline-block;
        opacity: 0;
    }

    .read-more::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: 0;
        left: 0;
        background-color: currentColor; /* currentColor usa el color activo del botón (var(--background) o var(--contrast)) */
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 0.3s ease-out;
    }

    .read-more:hover::after {
        transform: scaleX(1);
    }

    /* ==== RESPONSIVE ==== */
    @media (max-width: 1440px) {
        .title {
            font-size: clamp(3.5rem, 5vw, 4.5rem);
            height: auto;
            padding: 3vh 0;
        }
    }

    @media (max-width: 1024px) {
        .title {
            font-size: clamp(2.5rem, 5vw, 3.5rem);
            height: auto;
            padding: 3vh 0;
        }
        .services-button {
            font-size: 1.1rem;
            padding: 1rem 2.2rem;
        }
    }

    @media (max-width: 768px) {
        .title {
            font-size: clamp(1.8rem, 5vw, 2.2rem);
            height: auto;
            padding: 3vh 0;
            text-align: center;
        }
        .services-button {
            font-size: 0.95rem;
            padding: 0.9rem 1.8rem;
        }
    }
</style>
