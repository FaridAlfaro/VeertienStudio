---
import Text from "./Text.jsx";

const logos = [
    { src: "/empresas/image copy 2.png", alt: "Logo Empresa 2" },
    { src: "/empresas/image copy 3.png", alt: "Logo Empresa 3" },
    { src: "/empresas/image copy 4.png", alt: "Logo Empresa 4" },
    { src: "/empresas/image copy 5.png", alt: "Logo Empresa 5" },
    { src: "/empresas/image copy.png", alt: "Logo Empresa 6" },
    { src: "/empresas/image.png", alt: "Logo Empresa 7" },
    { src: "/empresas/miyo-logo.svg", alt: "Logo Empresa 8" },
];
---

<section class="social-proof" aria-labelledby="proof-title">
    <p id="proof-title" class="proof-texto">
        <Text client:only="react" i18nKey="social_proof.title" />
    </p>

    <div class="slider-container">
        <div class="logos-track">
            {
                [...logos, ...logos].map((logo, index) => (
                    <div class="logo-item" key={index}>
                        <img src={logo.src} alt={logo.alt} loading="lazy" />
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .social-proof {
        padding: 3vh 0 4vh;
        background: var(--contrast);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 5;
        overflow: hidden;
        flex-shrink: 0;
    }

    .proof-texto {
        font-size: clamp(1rem, 2vw, 2rem);
        color: var(--azul3);
        letter-spacing: 4px;
        margin-bottom: 4rem;
        font-weight: 700;
        opacity: 0.8;
    }

    .slider-container {
        width: 100%;
        overflow: hidden;
        position: relative;
        mask-image: linear-gradient(
            to right,
            transparent,
            black 10%,
            black 90%,
            transparent
        );
        -webkit-mask-image: linear-gradient(
            to right,
            transparent,
            black 10%,
            black 90%,
            transparent
        );
    }

    .logos-track {
        display: flex;
        width: fit-content;
        gap: 8rem;
        animation: scroll 40s linear infinite;
        padding: 1rem 0;
    }

    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            /* Se desplaza exactamente la mitad del ancho total del track (el set original de logos) */
            transform: translateX(-50%);
        }
    }

    .logo-item {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 180px;
        height: 60px;
        filter: grayscale(100%) brightness(2) opacity(0.7);
        transition: all 0.4s ease;
    }

    .logo-item:hover {
        filter: grayscale(0%) brightness(1) opacity(1);
        transform: scale(1.1);
    }

    .logo-item img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    /* Pausar animación al pasar el mouse por el contenedor general */
    .slider-container:hover .logos-track {
        animation-play-state: paused;
    }

    @media (max-width: 768px) {
        .logos-track {
            gap: 4rem;
            animation-duration: 25s;
        }
        .logo-item {
            width: 120px;
            height: 40px;
        }
        .proof-texto {
            font-size: 0.75rem;
            margin-bottom: 2.5rem;
        }
    }
</style>
